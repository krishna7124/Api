openapi: 3.0.3
info:
  title: KEVin KEV Query API (Community)
  version: "1.0.0"
  description: >
    Lightweight KEV query endpoints to support presence checks and by-ID fetches without downloading the full catalog.
    Use for targeted lookups only (community service; ~2 requests per second rate limit).

servers:
  - url: https://kevin.gtfkd.com

paths:
  /kev/exists:
    get:
      operationId: kevExists
      summary: Check if a CVE is in KEV
      description: Returns presence/boolean-style info for a given CVE ID.
      parameters:
        - in: query
          name: cve
          required: true
          schema: { type: string, example: CVE-2021-22681 }
      responses:
        "200":
          description: Presence info
          content:
            application/json:
              schema:
                type: object

  /kev/{cve}:
    get:
      operationId: kevById
      summary: Get KEV details by CVE ID
      description: Returns a KEV record for the specified CVE if present.
      parameters:
        - in: path
          name: cve
          required: true
          schema: { type: string, example: CVE-2021-22681 }
      responses:
        "200":
          description: KEV record details
          content:
            application/json:
              schema:
                type: object

  /kev:
    get:
      operationId: kevSearch
      summary: Search KEV by keyword or filter
      description: Keyword search with pagination (intended for quick, small result sets).
      parameters:
        - in: query
          name: search
          schema: { type: string, example: Rockwell }
        - in: query
          name: filter
          schema: { type: string, enum: [ransomware] }
        - in: query
          name: page
          schema: { type: integer, default: 1 }
        - in: query
          name: per_page
          schema: { type: integer, default: 25 }
      responses:
        "200":
          description: KEV list
          content:
            application/json:
              schema:
                type: array
                items: { type: object }
